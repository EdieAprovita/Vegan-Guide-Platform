# ---------------------------------------------------------------------------
# Environment variable template — copy to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.
# ---------------------------------------------------------------------------

# ── Authentication (REQUIRED) ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Backend API (REQUIRED) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# ── Site URL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google Maps (optional — map features disabled without it) ──────────────
# Create at https://console.cloud.google.com/apis/credentials
# Restrict by HTTP referrer; enable Maps JavaScript API only
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── PWA Push Notifications (optional) ──────────────────────────────────────
# Generate a key pair with: npm run generate-vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Observability (optional) ───────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=
OTEL_EXPORTER_OTLP_ENDPOINT=
