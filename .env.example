# ---------------------------------------------------------------------------
# Environment variable template — copy to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.
# ---------------------------------------------------------------------------

# ── Authentication (REQUIRED) ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# AUTH_SECRET is the secret actually used by the app/NextAuth.
AUTH_SECRET=

# Optional: legacy/alias for tooling that still expects NEXTAUTH_SECRET.
# If you set this, it MUST be identical to AUTH_SECRET above.
NEXTAUTH_SECRET=${AUTH_SECRET}

# NOTE: NEXTAUTH_URL is the base URL used by NextAuth for auth callbacks.
# It should usually match NEXT_PUBLIC_SITE_URL below to avoid mismatched
# auth callbacks vs. public/SEO URLs. Keep them in sync unless you have
# a specific reason to differ.
NEXTAUTH_URL=http://localhost:3000

# ── Backend API (REQUIRED) ─────────────────────────────────────────────────
# Default matches src/lib/api/config.ts BASE_URL fallback (port 5001, /api/v1).
# NOTE: README.md shows http://localhost:5000/api — that example is outdated.
# Run the backend with: cd ../api-guideTypescript && npm run dev
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# ── Site URL ───────────────────────────────────────────────────────────────
# NOTE: This is the public/SEO base URL. Keep it in sync with NEXTAUTH_URL
# above unless you have a specific reason to differ.
NEXT_PUBLIC_SITE_URL=

# ── Google Maps (optional — map features disabled without it) ──────────────
# Create at https://console.cloud.google.com/apis/credentials
# Restrict by HTTP referrer; enable Maps JavaScript API only
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── PWA Push Notifications (optional) ──────────────────────────────────────
# Generate a key pair with: npm run generate-vapid
# WARNING: Public key is exposed to the browser (NEXT_PUBLIC_ prefix).
#    Private key is SERVER-SIDE ONLY — NEVER commit it to version control.
#    If you accidentally commit VAPID_PRIVATE_KEY, anyone can forge notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# ── Observability (optional) ───────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry session replay sampling rate on error (0.0 – 1.0).
# Keep low in production to control cost and reduce GDPR/privacy exposure —
# full session replays on every error (1.0) capture PII and inflate quotas.
# Recommended: 0.1 (10 %) for production; 1.0 only in local dev.
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.1
