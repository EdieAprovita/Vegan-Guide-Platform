# ---------------------------------------------------------------------------
# Environment variable template — copy to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.
# ---------------------------------------------------------------------------

# PWA Push Notifications (VAPID)
# Generate a key pair with: npm run generate-vapid
# Public key is exposed to the browser (NEXT_PUBLIC_ prefix).
# Private key stays server-side only — never commit it.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@yourdomain.com
